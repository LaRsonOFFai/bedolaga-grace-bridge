diff --git a/app/services/grace_integration_service.py b/app/services/grace_integration_service.py
new file mode 100644
--- /dev/null
+++ b/app/services/grace_integration_service.py
@@ -0,0 +1,140 @@
+"""Coordination helpers for the external Bedolaga Grace Bridge.
+
+The module is a strict no-op while GRACE_INTEGRATION_ENABLED is false. Bridge
+state lives in its own PostgreSQL schema and never touches Bedolaga Alembic.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from datetime import UTC, datetime
+
+import structlog
+from sqlalchemy import text
+from sqlalchemy.ext.asyncio import AsyncSession
+
+from app.config import settings
+
+
+logger = structlog.get_logger(__name__)
+GRACE_PANEL_OWNED_STATES = frozenset({'pending_activate', 'active', 'exhausted', 'failed'})
+
+
+@dataclass(frozen=True, slots=True)
+class GraceState:
+    state: str
+    generation: int
+
+    @property
+    def owns_panel_access(self) -> bool:
+        return self.state in GRACE_PANEL_OWNED_STATES
+
+
+def is_grace_integration_enabled() -> bool:
+    return bool(settings.GRACE_INTEGRATION_ENABLED)
+
+
+async def acquire_grace_subscription_lock(db: AsyncSession, subscription_id: int) -> None:
+    if not is_grace_integration_enabled():
+        return
+    bind = db.get_bind()
+    if bind.dialect.name != 'postgresql':
+        logger.warning(
+            'Grace advisory lock is unavailable for a non-PostgreSQL database',
+            subscription_id=subscription_id,
+            dialect=bind.dialect.name,
+        )
+        return
+    result = await db.execute(
+        text('SELECT user_id FROM subscriptions WHERE id = :subscription_id'),
+        {'subscription_id': int(subscription_id)},
+    )
+    user_id = result.scalar_one_or_none()
+    if user_id is None:
+        return
+    await db.execute(
+        text('SELECT pg_advisory_xact_lock(:namespace, :subject)'),
+        {'namespace': int(settings.GRACE_LOCK_NAMESPACE), 'subject': int(user_id)},
+    )
+
+
+async def get_grace_state(db: AsyncSession, subscription_id: int) -> GraceState | None:
+    if not is_grace_integration_enabled():
+        return None
+    result = await db.execute(
+        text(
+            'SELECT state, generation FROM grace_bridge.access_state '
+            'WHERE subscription_id = :subscription_id'
+        ),
+        {'subscription_id': int(subscription_id)},
+    )
+    row = result.mappings().first()
+    if row is None:
+        return None
+    return GraceState(state=str(row['state']), generation=int(row['generation']))
+
+
+async def grace_owns_panel_access(db: AsyncSession, subscription_id: int) -> bool:
+    state = await get_grace_state(db, subscription_id)
+    return bool(state and state.owns_panel_access)
+
+
+async def invalidate_grace_for_paid_access(db: AsyncSession, subscription_id: int) -> bool:
+    """Make every older Grace operation for this Bedolaga user stale."""
+    if not is_grace_integration_enabled():
+        return False
+    now = datetime.now(UTC)
+    result = await db.execute(
+        text(
+            "UPDATE grace_bridge.access_state AS ga "
+            "SET state = 'inactive', generation = ga.generation + 1, "
+            "    last_error = NULL, updated_at = :now "
+            "FROM subscriptions AS owned, subscriptions AS target "
+            "WHERE target.id = :subscription_id "
+            "  AND owned.user_id = target.user_id "
+            "  AND ga.subscription_id = owned.id "
+            "  AND ga.state <> 'inactive' "
+            "RETURNING ga.subscription_id, ga.generation"
+        ),
+        {'subscription_id': int(subscription_id), 'now': now},
+    )
+    rows = result.all()
+    if not rows:
+        return False
+    await db.execute(
+        text(
+            "UPDATE grace_bridge.commands AS gc "
+            "SET state = 'stale', updated_at = :now "
+            "FROM grace_bridge.access_state AS ga, subscriptions AS owned, subscriptions AS target "
+            "WHERE target.id = :subscription_id "
+            "  AND owned.user_id = target.user_id "
+            "  AND ga.subscription_id = owned.id "
+            "  AND gc.subscription_id = ga.subscription_id "
+            "  AND gc.state IN ('pending', 'processing') "
+            "  AND gc.generation < ga.generation"
+        ),
+        {'subscription_id': int(subscription_id), 'now': now},
+    )
+    logger.info(
+        'Grace access invalidated by paid subscription state',
+        subscription_id=subscription_id,
+        invalidated_subscription_ids=[int(row[0]) for row in rows],
+    )
+    return True
+
+
+async def should_ignore_panel_event_during_grace(
+    db: AsyncSession,
+    subscription_id: int,
+    event_name: str,
+) -> bool:
+    if event_name not in {
+        'user.expired',
+        'user.disabled',
+        'user.enabled',
+        'user.limited',
+        'user.traffic_reset',
+        'user.modified',
+    }:
+        return False
+    return await grace_owns_panel_access(db, subscription_id)
